{
  "name": "foo-ui-webview2-demo",
  "version": "1.0.0",
  "description": "foo_ui_webview2 示例 Demo",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:only": "vite build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "deploy": "powershell -ExecutionPolicy Bypass -File deploy.ps1",
    "deploy:custom": "powershell -ExecutionPolicy Bypass -File deploy.ps1 -Fb2kPath",
    "build:deploy": "npm run build && npm run deploy",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "pinia": "^2.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.7",
    "tailwindcss": "^3.4.3",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38"
  }
}
