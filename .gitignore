# ============================================================
# foo_ui_webview2 .gitignore
# ============================================================

# ------ Build output directories ------
bin/
obj/
Debug/
Release/
x64/
x86/
Win32/
dist/
dist_repack*/

# ------ Build intermediates (global safety net) ------
*.iobj
*.ipdb
*.pch
*.pdb
*.idb
*.ilk
*.recipe
*.lastbuildstate
*.FileListAbsolute.txt
*.tlog/
pch.i

# ------ Build artifacts: .obj / .lib ------
# Exclude project-level build outputs.
*.obj
*.lib
# SDK prebuilt shared-platform libraries — intentionally tracked (ARM64EC/Win32/x64 variants not regenerated)
!lib/foobar2000_sdk/foobar2000/shared/*.lib
!lib/qengine/**/*.lib
# Note: SDK .obj and per-config .lib files are NOT tracked — regenerated by MSBuild

# ------ Visual Studio ------
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
*.VC.VC.opendb
*.cache

# ------ CMake / other build systems ------
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json

# ------ NuGet ------
packages/
*.nupkg
nuget.exe

# ------ Node / Frontend ------
node_modules/
web/node_modules/
web/dist/
sdk/node_modules/
sdk/dist/
sdk/.tsup/
# ------ Health audit tooling ------
.jscpd-report/
.npm/
.cache/
.eslintcache
.scannerwork/

# ------ Logs ------
log/
*.log
build_log*.txt
build_output*.txt
log.txt

# ------ Test output ------
test_output*.txt
test_output*.xml
test_results*.xml
test-results*.xml
test_detail*.json

# ------ WebView2 user data / local data ------
AppData/
WebView2/

# ------ OS files ------
Thumbs.db
.DS_Store

# ------ Python ------
__pycache__/
*.pyc
*.pyo

# ------ Temporary files ------
*.tmp
*.temp
~$*

# ------ Archive (completed task plans) ------
docs/archive/

# ------ External reference libs (not part of build) ------
lib/foo_artwork/
lib/foo_spider_monkey_panel/

bw-output/
.sonarlint

# ------ Static analysis ------
clang-tidy-report.txt
.clang-tidy-cache/

# ------ Local AI tool configs ------
.kilocode/
.roo/
.cursor/
.agent/
.agents/
.claude/
.continue/
.trae/
.windsurf/skills/
plans/
.windsurf/
.kiro/
# ------ Test outputs ------
test_output.txt

# ------ Audit / scratch outputs ------
# `_tmp_*` and `cpp_events.txt` are produced by ad-hoc audit scripts
# (scripts/audit_sdk_cpp_params.mjs and inline node one-liners) for
# diff-style debugging. They are regenerated on demand and must not
# enter version control.
_tmp_*.txt
_tmp_*.json
.tmp_*.json
cpp_events.txt

# ------ VitePress cache ------
docs/vitepress/.vitepress/cache/
.windsurf/rules/cpp-runtime.md

# ------ Local scratch / vendor copies ------
# `.vite/` is the Vitest watch-mode cache emitted under the workspace
# root; `temp_sdk/` is an ad-hoc local copy of `sdk/` produced by
# previous workflow sessions. Both are regenerated on demand and must
# never enter version control.
.vite/
temp_sdk/

# 

# ------ npm pack outputs ------
# Tarball produced by npm pack from sdk/ or mcp/ - never commit.
sdk/*.tgz
mcp/*.tgz

# ------ npm credentials ------
# .npmrc only references ${NPM_TOKEN} (publish auth); the token lives in a
# system env var, never in VCS. Ignore every .npmrc to keep credentials out.
.npmrc

# ------ Externally-cloned CUI SDK (no longer a submodule) ------
# lib/columns_ui-sdk is fetched at build time (CI: git clone reupen/columns_ui-sdk);
# the broken submodule gitlink was removed. Ignore the local working copy so it is
# never accidentally committed into this repo.
lib/columns_ui-sdk/

# ------ Ad-hoc test capture (hyphen variant) ------
# `npm test > test-output.txt` scratch capture (mcp/ etc.) - never commit.
test-output*.txt

# ------ 5/18 cleanup recovery (2026-05) ------
# Recovery mirror + helper scripts produced during the post-cleanup
# salvage. The mirror is a side-channel inventory; the helper scripts
# are one-off operational artifacts. Neither belongs in git.
.recovered/
.recover_local_history.mjs
.scan_local_history.mjs
.scan-recovery.txt
.scan-recovery-all.txt
.scan_classify_recovery.ps1
.scan_dg_extras.ps1
.scan_corruption.ps1
.scan_corruption_all.ps1
.scan_corruption_v3.ps1
.scan_all_restored_corruption.ps1
.scan_missing_inventory.ps1
.restore_batch.ps1
.restore_dg_extras.ps1
scan-result.txt
log.txt
docs/vitepress/dist/
docs/vitepress/build-log.txt
docs/vitepress/.fix-headings.ps1
.tmp_kiro_scan/

# OpenCode agent config (local only, not for version control)
.opencode/

# ------ Local CI reports (2026-06) ------
# JSON reports generated by scripts/local-ci.ps1 are local diagnostic
# artifacts; they accumulate per run and are not part of the contract
# surface. Long-running trends should be kept on the developer machine
# and rotated manually to F:\foo_ui_webview2_backup\local-ci-archive\.
docs/report/local-ci/*.json